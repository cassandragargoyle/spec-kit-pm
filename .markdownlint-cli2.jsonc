{
  // Glob patterns for files to lint
  "globs": [
    "docs/**/*.md",
    "*.md",
    "src/*/README.md",
    "synapse-reference-ui/README.md"
  ],
  // Glob patterns for files to ignore
  "ignores": [
    "docs/adr/**",
    "docs/issues/internal/**",
    "docs/testing/**",
    "docs/private/**",
    "docs/notes/**",
    "CLAUDE.md",
    "CLAUDE.local.md",
    "GEMINI.md",
    "NOTES.md",
    "TODO.md",
    ".claude/**",
    ".translated/**",
    ".venv/**",
    "node_modules/**",
    "dist/**",
    "**/target/**",
    "**/node_modules/**"
  ]
}
